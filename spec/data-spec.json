{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "数据规格定义 - 支持多语言（en/zh），数据文件分别位于 src/data/en.ts 和 src/data/zh.ts",
  "definitions": {
    "Skill": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "技能唯一标识"
        },
        "name": {
          "type": "string",
          "description": "技能名称"
        },
        "category": {
          "type": "string",
          "enum": ["frontend", "backend", "database", "devops", "tools", "other"],
          "description": "技能分类"
        },
        "level": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "技能熟练度百分比"
        },
        "icon": {
          "type": "string",
          "description": "技能图标名称（使用lucide-react图标库）"
        }
      },
      "required": ["id", "name", "category", "level"]
    },
    "Project": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "项目唯一标识"
        },
        "name": {
          "type": "string",
          "description": "项目名称"
        },
        "description": {
          "type": "string",
          "description": "项目简短描述"
        },
        "longDescription": {
          "type": "string",
          "description": "项目详细描述"
        },
        "image": {
          "type": "string",
          "description": "项目截图URL"
        },
        "technologies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "技术栈列表"
        },
        "githubUrl": {
          "type": "string",
          "format": "uri",
          "description": "GitHub仓库链接"
        },
        "demoUrl": {
          "type": "string",
          "format": "uri",
          "description": "项目演示链接"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "项目标签"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "in-progress", "paused"],
          "description": "项目状态"
        },
        "startDate": {
          "type": "string",
          "format": "date",
          "description": "项目开始日期"
        },
        "endDate": {
          "type": "string",
          "format": "date",
          "description": "项目结束日期"
        }
      },
      "required": ["id", "name", "description", "image", "technologies"]
    },
    "ContactInfo": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "邮箱地址"
        },
        "github": {
          "type": "string",
          "format": "uri",
          "description": "GitHub个人主页"
        },
        "linkedin": {
          "type": "string",
          "format": "uri",
          "description": "LinkedIn个人主页"
        },
        "twitter": {
          "type": "string",
          "format": "uri",
          "description": "Twitter个人主页"
        },
        "website": {
          "type": "string",
          "format": "uri",
          "description": "个人网站"
        }
      },
      "required": ["email", "github"]
    },
    "PersonalInfo": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "姓名"
        },
        "title": {
          "type": "string",
          "description": "职位/头衔"
        },
        "bio": {
          "type": "string",
          "description": "个人简介"
        },
        "avatar": {
          "type": "string",
          "format": "uri",
          "description": "头像URL"
        },
        "location": {
          "type": "string",
          "description": "所在地"
        },
        "summary": {
          "type": "string",
          "description": "一句话介绍"
        }
      },
      "required": ["name", "title", "bio"]
    },
    "SocialLink": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "社交平台名称"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "社交平台链接"
        },
        "icon": {
          "type": "string",
          "description": "图标名称"
        }
      },
      "required": ["name", "url", "icon"]
    }
  },
  "type": "object",
  "properties": {
    "personalInfo": {
      "$ref": "#/definitions/PersonalInfo"
    },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Skill"
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Project"
      }
    },
    "contactInfo": {
      "$ref": "#/definitions/ContactInfo"
    },
    "socialLinks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/SocialLink"
      }
    }
  },
  "required": ["personalInfo", "skills", "projects", "contactInfo"]
}